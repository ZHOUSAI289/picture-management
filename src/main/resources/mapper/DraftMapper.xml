<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.gzlg.mapper.DraftMapper">

    <resultMap id="imageMap" type="com.gzlg.pojo.vo.PhotoVO">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="category" column="category"/>
        <result property="photographer" column="photographer"/>
        <result property="personName" column="person_name"/>
        <result property="date" column="date"/>
        <result property="url" column="url"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 查询草稿 -->
    <select id="findDraft" resultMap="imageMap">
        SELECT
        id, title, category, photographer, person_name, date, url, description, status,
        created_at, updated_at
        FROM image
        WHERE status = 'draft'
        ORDER BY updated_at DESC
        LIMIT 1
    </select>

</mapper>
