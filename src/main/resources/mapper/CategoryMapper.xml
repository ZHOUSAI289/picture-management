<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.gzlg.mapper.CategoryMapper">

    <resultMap id="categoryMap" type="com.gzlg.pojo.entity.Category">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="count" column="count"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <!-- 获取所有分类 -->
    <select id="findAll" resultMap="categoryMap">
        SELECT id, name, created_at
        FROM category
        ORDER BY created_at DESC
    </select>

    <!-- 根据ID查询分类 -->
    <select id="findById" parameterType="int" resultMap="categoryMap">
        SELECT id, name, created_at
        FROM category
        WHERE id = #{id}
    </select>

    <!-- 根据名称查询分类 -->
    <select id="findByName" parameterType="string" resultMap="categoryMap">
        SELECT id, name, created_at
        FROM category
        WHERE name = #{name}
    </select>

    <!-- 新增分类 -->
    <insert id="insert" parameterType="com.gzlg.pojo.entity.Category" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO category (name, created_at)
        VALUES (#{name}, #{createdAt})
    </insert>

    <!-- 根据ID删除分类 -->
    <delete id="deleteById" parameterType="int">
        DELETE FROM category WHERE id = #{id}
    </delete>

    <!-- 统计某分类下的图片数量 -->
    <select id="countImagesByCategory" parameterType="string" resultType="int">
        SELECT COUNT(*)
        FROM image
        WHERE category = #{categoryName}
    </select>

    <!-- 获取所有分类及其图片数量 -->
    <select id="findAllWithCount" resultMap="categoryMap">
        SELECT 
            c.id, 
            c.name, 
            c.created_at,
            COUNT(i.id) AS count
        FROM category c
        LEFT JOIN image i ON c.name = i.category
        GROUP BY c.id, c.name, c.created_at
        ORDER BY c.created_at DESC
    </select>

    <!-- 批量更新图片分类 -->
    <update id="batchUpdateCategory">
        UPDATE image
        SET category = #{category},
            updated_at = NOW()
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <!-- 批量审核图片 -->
    <update id="batchUpdateStatus">
        UPDATE image
        SET status = #{status},
            updated_at = NOW()
        WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

</mapper>
